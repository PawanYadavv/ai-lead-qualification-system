APP_NAME=AI Lead Qualification System
APP_ENV=development
API_V1_PREFIX=/api/v1
API_BASE_URL=http://localhost
FRONTEND_BASE_URL=http://localhost:8080

API_HOST_PORT=8000
POSTGRES_HOST_PORT=5432

SECRET_KEY=change-this-to-a-long-random-string
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

DATABASE_URL=postgresql+psycopg2://postgres:postgres@db:5432/lead_qualification
PGHOST=
PGPORT=5432
PGUSER=
PGPASSWORD=
PGDATABASE=
DATABASE_SSLMODE=prefer

OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

USE_QDRANT=false
QDRANT_URL=http://qdrant:6333
QDRANT_API_KEY=

SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_USE_TLS=true
SMTP_FROM_EMAIL=noreply@example.com

BACKEND_CORS_ORIGINS=http://localhost:3000,http://localhost:5173,http://localhost:8080,http://localhost

# Railway production overrides (set these in Railway Variables tab)
# APP_ENV=production
# API_BASE_URL=https://your-api-service.up.railway.app
# FRONTEND_BASE_URL=https://your-frontend-domain.com
# BACKEND_CORS_ORIGINS=https://your-frontend-domain.com
# DATABASE_SSLMODE=require






